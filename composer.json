{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": ["framework", "laravel"],
    "license": "MIT",
    "repositories": [
        {
            "type": "path",
            "url": "package-manager/available",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "package-manager/categories",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "package-manager/addresses",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "package-manager/language",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "package-manager/tools",
            "options": {
                "symlink": true
            }
        }
    ],
    "require": {
        "php": "^8.1",
        "arrilot/laravel-widgets": "^3.14",
        "datasdk/addresses": "^1.0",
        "datasdk/available": "^1.0",
        "datasdk/categories": "^1.0",
        "datasdk/language": "^1.0",
        "datasdk/tools": "^1.0",
        "dompdf/dompdf": "3.1",
        "guzzlehttp/guzzle": "^7.2",
        "intervention/image": "3.11",
        "kalnoy/nestedset": "6.0.7",
        "laraeast/laravel-settings": "^2.0",
        "laravel/framework": "^10.0",
        "laravel/sanctum": "^3.2",
        "laravelcm/laravel-subscriptions": "1.8",
        "lecturize/laravel-addresses": "*",
        "multicaret/laravel-acquaintances": "3.7",
        "musonza/chat": "6.3",
        "netsells/laravel-geoscope": "*",
        "nwidart/laravel-modules": "^10.0",
        "opcodesio/log-viewer": "^3.21",
        "psr/log": "3.0",
        "spatie/eloquent-sortable": "*",
        "spatie/laravel-medialibrary": "11.0",
        "spatie/laravel-permission": "6.0",
        "spatie/laravel-sluggable": "3.8.1",
        "spatie/laravel-tags": "^4.11",
        "spatie/laravel-translatable": "^6.11",
        "spatie/laravel-translation-loader": "^2.8",
        "studio/laravel-totem": "11.1",
        "tailflow/laravel-orion": "^2.23",
        "turahe/laravel-counters": "1.1",
        "waltersilvacruz/laravel-shortcodes": "1.0.22"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9.1",
        "laravel/breeze": "^1.29",
        "laravel/pint": "^1.0",
        "laravel/sail": "^1.18",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^7.0",
        "phpunit/phpunit": "^10.0",
        "spatie/laravel-ignition": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Modules\\": "Modules/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "exclude-from-classmap": [
            "Modules/*/vendor/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "branch-alias": {
            "dev-master": "10.x-dev"
        },
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "wikimedia/composer-merge-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
